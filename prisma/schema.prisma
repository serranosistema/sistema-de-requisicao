generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  
  // Relacionamentos
  users     User[]
  sectors   Sector[] // Uma loja tem vários setores
  items     Item[]   // Uma loja tem vários itens

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  REPOSITOR
  ESTOQUISTA
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// === NOVAS TABELAS ABAIXO ===

model Sector {
  id        String   @id @default(cuid())
  code      String   @unique // <-- NOVO CAMPO
  name      String

  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  items     Item[]   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id        String   @id @default(cuid())
  code      String   @unique // <-- NOVO CAMPO OBRIGATÓRIO
  name      String   // Vamos usar esse campo para a "Descrição"
  unit      String   @default("UN")
  cost      Float?   
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  sectors   Sector[] 
  
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}